# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# NLP Configuration
SPACY_MODEL=en_core_web_sm
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Model Configuration
XGB_N_ESTIMATORS=100
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.1

# Scraper Configuration
SCRAPER_TIMEOUT=10
SCRAPER_DELAY=2
MAX_PAGES=50

# Logging
LOG_LEVEL=INFO

# Development
ENVIRONMENT=production

# LLM Extraction (set accuracy-first)
USE_LLM_EXTRACTION=true
LLM_PROVIDER=groq              # groq | together | openai
LLM_API_KEY=                   # paste your key here (do NOT commit it)
LLM_MODEL=llama-3.1-8b-instant # together: qwen2.5-72b-instruct; openai: gpt-4o or gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_MAX_INPUT_CHARS=20000