# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# NLP Configuration
SPACY_MODEL=en_core_web_sm
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Model Configuration
XGB_N_ESTIMATORS=100
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.1

# Scraper Configuration
SCRAPER_TIMEOUT=10
SCRAPER_DELAY=2
MAX_PAGES=50

# Logging
LOG_LEVEL=INFO

# Development
ENVIRONMENT=production